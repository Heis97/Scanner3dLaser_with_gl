// Получение значения вокселя по координатам (x, y, z) в диапазоне [0..size-1]
uint getVoxel(int x, int y, int z) {
    if (x < 0 || x >= width || y < 0 || y >= height || z < 0 || z >= depth)
        return 0;
    int idx = x + y * width + z * width * height;
    return voxels[idx];
}

// Получение позиции вершины куба (0..7) в мировых координатах (целые индексы вокселей)
vec3 getVertexPosition(int vertex, int x, int y, int z) {
    // vertex: 0..7, биты: 1=x, 2=y, 4=z (по стандарту Marching Cubes)
    float dx = float((vertex & 1) != 0 ? 1 : 0);
    float dy = float((vertex & 2) != 0 ? 1 : 0);
    float dz = float((vertex & 4) != 0 ? 1 : 0);
    return vec3(float(x) + dx, float(y) + dy, float(z) + dz);
}

// Интерполяция точки на ребре между двумя вершинами v1 и v2
// val1, val2 – значения вокселей (0 или 1). Для isoLevel=0.5 даёт среднюю точку.
vec3 interpolate(vec3 p1, vec3 p2, float val1, float val2) {
    if (abs(isoLevel - val1) < 0.00001) return p1;
    if (abs(isoLevel - val2) < 0.00001) return p2;
    float t = (isoLevel - val1) / (val2 - val1);
    return p1 + t * (p2 - p1);
}

// ---------------------------- Основная функция шейдера ----------------------------
layout(local_size_x = 8, local_size_y = 8, local_size_z = 8) in;
void main() {
    vec3 vertList[12] = vec3[12](vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0), vec3(0.0));
    // Глобальный ID куба (в воксельных единицах)
    ivec3 cubePos = ivec3(gl_GlobalInvocationID.xyz);
    int x = cubePos.x;
    int y = cubePos.y;
    int z = cubePos.z;
    
    // Проверка границ: обрабатываем кубы только внутри сетки (последний воксель по каждому измерению не может быть началом куба)
    if (x >= width - 1 || y >= height - 1 || z >= depth - 1)
        return;
    
    // Чтение значений 8 вершин куба
    uint v[8];
    v[0] = getVoxel(x,   y,   z);
    v[1] = getVoxel(x+1, y,   z);
    v[2] = getVoxel(x+1, y,   z+1);
    v[3] = getVoxel(x,   y,   z+1);
    v[4] = getVoxel(x,   y+1, z);
    v[5] = getVoxel(x+1, y+1, z);
    v[6] = getVoxel(x+1, y+1, z+1);
    v[7] = getVoxel(x,   y+1, z+1);
    
    // Вычисление индекса куба (битовая маска вершин, превышающих isoLevel)
    int cubeIndex = 0;
    for (int i = 0; i < 8; i++) {
        if (float(v[i]) > isoLevel)
            cubeIndex |= (1 << i);
    }
    
    // Если куб полностью внутри или снаружи – выходим
    if (edgeTable[cubeIndex] == 0)
        return;
    
    // Вычисление 12 точек пересечения на рёбрах (если ребро пересекается)
    
    // Рёбра: стандартная нумерация Marching Cubes (см. edgeTable)
    // 0: (0,1), 1: (1,2), 2: (2,3), 3: (3,0), 4: (4,5), 5: (5,6), 6: (6,7), 7: (7,4), 8: (0,4), 9: (1,5), 10: (2,6), 11: (3,7)
    if ((edgeTable[cubeIndex] & 1) != 0) vertList[0] = interpolate(getVertexPosition(0, x,y,z), getVertexPosition(1, x,y,z), float(v[0]), float(v[1]));
    if ((edgeTable[cubeIndex] & 2) != 0) vertList[1] = interpolate(getVertexPosition(1, x,y,z), getVertexPosition(2, x,y,z), float(v[1]), float(v[2]));
    if ((edgeTable[cubeIndex] & 4) != 0) vertList[2] = interpolate(getVertexPosition(2, x,y,z), getVertexPosition(3, x,y,z), float(v[2]), float(v[3]));
    if ((edgeTable[cubeIndex] & 8) != 0) vertList[3] = interpolate(getVertexPosition(3, x,y,z), getVertexPosition(0, x,y,z), float(v[3]), float(v[0]));
    if ((edgeTable[cubeIndex] & 16) != 0) vertList[4] = interpolate(getVertexPosition(4, x,y,z), getVertexPosition(5, x,y,z), float(v[4]), float(v[5]));
    if ((edgeTable[cubeIndex] & 32) != 0) vertList[5] = interpolate(getVertexPosition(5, x,y,z), getVertexPosition(6, x,y,z), float(v[5]), float(v[6]));
    if ((edgeTable[cubeIndex] & 64) != 0) vertList[6] = interpolate(getVertexPosition(6, x,y,z), getVertexPosition(7, x,y,z), float(v[6]), float(v[7]));
    if ((edgeTable[cubeIndex] & 128) != 0) vertList[7] = interpolate(getVertexPosition(7, x,y,z), getVertexPosition(4, x,y,z), float(v[7]), float(v[4]));
    if ((edgeTable[cubeIndex] & 256) != 0) vertList[8] = interpolate(getVertexPosition(0, x,y,z), getVertexPosition(4, x,y,z), float(v[0]), float(v[4]));
    if ((edgeTable[cubeIndex] & 512) != 0) vertList[9] = interpolate(getVertexPosition(1, x,y,z), getVertexPosition(5, x,y,z), float(v[1]), float(v[5]));
    if ((edgeTable[cubeIndex] & 1024) != 0) vertList[10] = interpolate(getVertexPosition(2, x,y,z), getVertexPosition(6, x,y,z), float(v[2]), float(v[6]));
    if ((edgeTable[cubeIndex] & 2048) != 0) vertList[11] = interpolate(getVertexPosition(3, x,y,z), getVertexPosition(7, x,y,z), float(v[3]), float(v[7]));
    
    // Подсчёт количества треугольников для этого куба
    int numTriangles = 0;
    int base = cubeIndex * 16;
    for (int i = 0; i < 5; i++) {
        int i0 = triTable[base + i*3];
        if (i0 == -1) break;
        numTriangles++;
    }
    
    if (pass == 0) {
        // Первый проход: только подсчёт вершин и индексов
        uint vertexCount = numTriangles * 3;
        atomicCounterAdd(vertexCounter, vertexCount);
        atomicCounterAdd(indexCounter, vertexCount);
    } else {
        // Второй проход: запись вершин и индексов в выходные буферы
        // Получаем глобальные смещения для записи
        uint baseVertex = atomicCounterAdd(vertexCounter, numTriangles * 3);
        uint baseIndex = atomicCounterAdd(indexCounter, numTriangles * 3);
        
        // Для каждого треугольника
        for (int tri = 0; tri < numTriangles; tri++) {
            int i0 = triTable[base + tri*3];
            if (i0 == -1) break;
            int i1 = triTable[base + tri*3 + 1];
            int i2 = triTable[base + tri*3 + 2];
            vec3 v0 = vertList[i0];
            vec3 v1 = vertList[i1];
            vec3 v2 = vertList[i2];
            
            // Запись вершин
            vertices[baseVertex + tri*3 + 0] = v0;
            vertices[baseVertex + tri*3 + 1] = v1;
            vertices[baseVertex + tri*3 + 2] = v2;
            
            // Запись индексов (просто последовательные)
            indices[baseIndex + tri*3 + 0] = baseVertex + tri*3 + 0;
            indices[baseIndex + tri*3 + 1] = baseVertex + tri*3 + 1;
            indices[baseIndex + tri*3 + 2] = baseVertex + tri*3 + 2;
        }
    }
}